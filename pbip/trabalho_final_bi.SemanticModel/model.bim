                "    #\"Replaced Value\" = Table.ReplaceValue(#\"Colunas Reordenadas\",\"No\",\"Não usa\",Replacer.ReplaceText,{\"Metformina\", \"Repaglinida\", \"Clorpropamida\", \"Nateglinida\", \"Acetohexamida\", \"Glimepirida\", \"Glipizida\", \"Gliburida\", \"Tolbutamida\", \"Pioglitazona\", \"Rosiglitazona\", \"Acarbose\", \"Miglitol\", \"Troglitazona\", \"Tolazamida\", \"Examida\", \"Sitagliptin\", \"Insulina\", \"Gliburida-Metformina\", \"Glipizida-Metformina\", \"Metformina-Rosiglitazona\", \"Metformina_pioglitazona\", \"Mudou_medicamento\", \"Prescricao_de_Medicamento\"}),",
