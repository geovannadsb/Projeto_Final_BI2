                "    #\"Replaced Value2\" = Table.ReplaceValue(#\"Replaced Value1\",\"Up\",\"Aumentou dose\",Replacer.ReplaceText,{\"Metformina\", \"Repaglinida\", \"Clorpropamida\", \"Nateglinida\", \"Acetohexamida\", \"Glimepirida\", \"Glipizida\", \"Gliburida\", \"Tolbutamida\", \"Pioglitazona\", \"Rosiglitazona\", \"Acarbose\", \"Miglitol\", \"Troglitazona\", \"Tolazamida\", \"Examida\", \"Sitagliptin\", \"Insulina\", \"Gliburida-Metformina\", \"Glipizida-Metformina\", \"Metformina-Rosiglitazona\", \"Metformina_pioglitazona\"}),",
                "    #\"Replaced Value3\" = Table.ReplaceValue(#\"Replaced Value2\",\"Down\",\"Reduziu dose\",Replacer.ReplaceText,{\"Metformina\", \"Repaglinida\", \"Clorpropamida\", \"Nateglinida\", \"Acetohexamida\", \"Glimepirida\", \"Glipizida\", \"Gliburida\", \"Tolbutamida\", \"Pioglitazona\", \"Rosiglitazona\", \"Acarbose\", \"Miglitol\", \"Troglitazona\", \"Tolazamida\", \"Examida\", \"Sitagliptin\", \"Insulina\", \"Gliburida-Metformina\", \"Glipizida-Metformina\", \"Metformina-Rosiglitazona\", \"Metformina_pioglitazona\"}),",
