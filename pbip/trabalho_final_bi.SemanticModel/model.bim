                "    #\"Colunas Renomeadas1\" = Table.RenameColumns(#\"Colunas Removidas1\",{{\"change\", \"Mudou_medicamento\"}, {\"diabetesMed\", \"Prescricao_de_Medicamento\"}, {\"readmitted\", \"Readmissao\"}, {\"paciente_nbr\", \"Paciente_Nbr\"}, {\"raca\", \"Raca\"}, {\"genero\", \"Genero\"}, {\"idade\", \"Idade\"}, {\"metformin-pioglitazone\", \"Metformina_pioglitazona\"}}),",
